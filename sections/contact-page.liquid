

<script
  src="{{ 'reveal-on-scroll.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div class="contact-page page-width-content">
  <reveal-on-scroll class="contact-page__intro">
    <p class="contact-page__intro-text">{{ section.settings.intro_text }}</p>
  </reveal-on-scroll>

  <div class="contact-page__grid">
    <reveal-on-scroll class="contact-page__form-card">
      {% assign form_id = section.id | prepend: 'ContactPage-' %}
      {%- form 'contact', id: form_id, class: 'contact-page__form' -%}
        <input
          name="contact[id]"
          type="hidden"
          value="{{ form_id }}"
        >

        {% liquid
          assign form_matches = false
          if form.id == form_id or form.id == blank
            assign form_matches = true
          endif
        %}

        {%- if form.errors and form_matches -%}
          <div
            class="contact-page__message contact-page__message--error"
            tabindex="-1"
            autofocus
          >
            {{- 'icon-error.svg' | inline_asset_content -}}
            {{- form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email -}}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? and form_matches -%}
          <div
            class="contact-page__message contact-page__message--success"
            tabindex="-1"
            autofocus
          >
            {{- 'icon-checkmark.svg' | inline_asset_content -}}
            {{- 'blocks.contact_form.post_success' | t -}}
          </div>
        {%- endif -%}

        <div class="contact-page__field-row">
          <div class="contact-page__field">
            <label for="ContactPage-name-{{ section.id }}">{{ section.settings.label_name }}</label>
            <input
              type="text"
              id="ContactPage-name-{{ section.id }}"
              autocomplete="name"
              name="contact[name]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            >
          </div>

          <div class="contact-page__field">
            <label for="ContactPage-email-{{ section.id }}">
              {{ section.settings.label_email }}
              <span aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="ContactPage-email-{{ section.id }}"
              autocomplete="email"
              name="contact[email]"
              spellcheck="false"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' and form_matches %}
                aria-invalid="true"
              {% endif %}
              required
            >
          </div>
        </div>

        <div class="contact-page__field-row">
          <div class="contact-page__field">
            <label for="ContactPage-phone-{{ section.id }}">{{ section.settings.label_phone }}</label>
            <input
              type="tel"
              id="ContactPage-phone-{{ section.id }}"
              autocomplete="tel"
              name="contact[phone]"
              pattern="[0-9\-]*"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
            >
          </div>

          <div class="contact-page__field">
            <label for="ContactPage-subject-{{ section.id }}">{{ section.settings.label_subject }}</label>
            <input
              type="text"
              id="ContactPage-subject-{{ section.id }}"
              name="contact[subject]"
            >
          </div>
        </div>

        <div class="contact-page__field">
          <label for="ContactPage-body-{{ section.id }}">{{ section.settings.label_message }}</label>
          <textarea
            rows="6"
            id="ContactPage-body-{{ section.id }}"
            name="contact[body]"
          >{{- form.body -}}</textarea>
        </div>

        <button
          type="submit"
          class="contact-page__submit"
        >
          {{ section.settings.label_submit }}
        </button>
      {%- endform -%}
    </reveal-on-scroll>

    <reveal-on-scroll class="contact-page__info-card">
      <div class="contact-page__info-row">
        <span class="contact-page__info-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
      </div>

      <div class="contact-page__info-row">
        <span class="contact-page__info-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6.5 3.5c.7 0 1.3.4 1.6 1l1 2c.3.6.2 1.3-.3 1.8L7.5 9.6c1 2.4 2.9 4.3 5.3 5.3l1.3-1.3c.5-.5 1.2-.6 1.8-.3l2 1c.6.3 1 .9 1 1.6v1.7c0 1.2-1.1 2.1-2.3 1.9C10.9 18.7 5.3 13.1 4.4 6.4c-.2-1.2.7-2.3 1.9-2.3h.2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </span>
        <a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a>
      </div>

      <div class="contact-page__divider"></div>

      <div class="contact-page__hours">
        <div class="contact-page__info-row">
          <span class="contact-page__info-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="8.25" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 7.5V12l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span>{{ section.settings.hours_label }}</span>
        </div>
        <p class="contact-page__hours-days">{{ section.settings.hours_days }}</p>
        <p class="contact-page__hours-time">{{ section.settings.hours_time }}</p>
      </div>
    </reveal-on-scroll>
  </div>

  <reveal-on-scroll class="contact-page__footer">
    <p>{{ section.settings.footer_message }}</p>
  </reveal-on-scroll>
</div>

{% stylesheet %}
  .contact-page {
    padding-block: 24px 96px;
  }

  .contact-page__intro {
    display: block;
    text-align: center;
    margin-block-end: 56px;
  }

  .contact-page__intro-text {
    font-family: var(--font-body--family);
    font-size: 1.2rem;
    line-height: 1.6;
    color: rgb(var(--color-foreground-rgb) / 70%);
    max-width: 34rem;
    margin-inline: auto;
  }

  .contact-page__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 28px;
    align-items: start;
  }

  @media screen and (max-width: 749px) {
    .contact-page__grid {
      grid-template-columns: 1fr;
    }
  }

  .contact-page__form-card,
  .contact-page__info-card {
    display: block;
    background-color: #ffffff;
    border-radius: 24px;
    box-shadow: 0 2px 8px rgba(26, 26, 46, 0.06), 0 16px 40px rgba(26, 26, 46, 0.08);
    padding: 40px;
  }

  @media screen and (max-width: 749px) {
    .contact-page__form-card,
    .contact-page__info-card {
      padding: 28px 24px;
    }
  }

  .contact-page__info-card {
    background-color: #f7f5f2;
    box-shadow: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-page__form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-page__field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  @media screen and (max-width: 549px) {
    .contact-page__field-row {
      grid-template-columns: 1fr;
    }
  }

  .contact-page__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-page__field label {
    font-size: 0.9rem;
    color: rgb(var(--color-foreground-rgb) / 65%);
  }

  .contact-page__field input,
  .contact-page__field textarea {
    font-family: var(--font-body--family);
    font-size: 1rem;
    padding: 14px 18px;
    border-radius: 14px;
    border: 1px solid rgb(var(--color-foreground-rgb) / 15%);
    background-color: #ffffff;
    color: var(--color-foreground);
    transition: border-color 0.25s ease-in-out, box-shadow 0.25s ease-in-out;
  }

  .contact-page__field textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .contact-page__field input:focus,
  .contact-page__field textarea:focus {
    outline: none;
    border-color: #1a1a2e;
    box-shadow: 0 0 0 3px rgba(26, 26, 46, 0.1);
  }

  .contact-page__submit {
    align-self: flex-end;
    font-family: var(--font-body--family);
    font-size: 1rem;
    color: #ffffff;
    background-color: #1a1a2e;
    border: 1px solid #1a1a2e;
    border-radius: 999px;
    padding: 14px 32px;
    cursor: pointer;
    transition: transform 0.3s ease-in-out, background-color 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
  }

  .contact-page__submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(26, 26, 46, 0.2);
  }

  .contact-page__message {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    border-radius: 14px;
    font-size: 0.95rem;
  }

  .contact-page__message--success {
    background-color: rgba(70, 140, 100, 0.1);
    color: #2f6b47;
  }

  .contact-page__message--error {
    background-color: rgba(180, 60, 60, 0.08);
    color: #a13a3a;
  }

  .contact-page__info-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1rem;
  }

  .contact-page__info-row a {
    color: var(--color-foreground);
    text-decoration: none;
  }

  .contact-page__info-row a:hover {
    text-decoration: underline;
  }

  .contact-page__info-icon {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: #ffffff;
    color: #1a1a2e;
  }

  .contact-page__info-icon svg {
    width: 18px;
    height: 18px;
  }

  .contact-page__divider {
    height: 1px;
    background-color: rgb(var(--color-foreground-rgb) / 12%);
  }

  .contact-page__hours {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contact-page__hours-days,
  .contact-page__hours-time {
    margin: 0;
    padding-inline-start: 52px;
    color: rgb(var(--color-foreground-rgb) / 70%);
    font-size: 0.95rem;
  }

  .contact-page__footer {
    display: block;
    text-align: center;
    margin-block-start: 72px;
  }

  .contact-page__footer p {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 1.35rem;
    line-height: 1.6;
    color: #1a1a2e;
    max-width: 36rem;
    margin-inline: auto;
  }

  @media (prefers-reduced-motion: no-preference) {
    reveal-on-scroll {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    reveal-on-scroll.is-revealed {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact page",
  "settings": [
    {
      "type": "text",
      "id": "intro_text",
      "label": "Intro text",
      "default": "נשמח לעזור בכל שאלה, בקשה או התייעצות."
    },
    {
      "type": "text",
      "id": "label_name",
      "label": "Name field label",
      "default": "שם מלא"
    },
    {
      "type": "text",
      "id": "label_email",
      "label": "Email field label",
      "default": "כתובת אימייל"
    },
    {
      "type": "text",
      "id": "label_phone",
      "label": "Phone field label",
      "default": "טלפון (אופציונלי)"
    },
    {
      "type": "text",
      "id": "label_subject",
      "label": "Subject field label",
      "default": "נושא"
    },
    {
      "type": "text",
      "id": "label_message",
      "label": "Message field label",
      "default": "הודעה"
    },
    {
      "type": "text",
      "id": "label_submit",
      "label": "Submit button label",
      "default": "שלחו הודעה"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "support@tmunalabait.co.il"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Contact phone",
      "default": "050-000-0000"
    },
    {
      "type": "text",
      "id": "hours_label",
      "label": "Hours label",
      "default": "שעות פעילות"
    },
    {
      "type": "text",
      "id": "hours_days",
      "label": "Hours days",
      "default": "ימים א' עד ה'"
    },
    {
      "type": "text",
      "id": "hours_time",
      "label": "Hours time",
      "default": "09:00-18:00"
    },
    {
      "type": "textarea",
      "id": "footer_message",
