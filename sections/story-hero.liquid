

<div class="story-hero page-width-content" style="background-color: {{ section.settings.background_color }};">
  <div class="story-hero__grid">
    <div class="story-hero__media" style="--story-hero-media-height: {{ section.settings.media_height }};">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1600
          | image_tag: loading: 'lazy', class: 'story-hero__image', sizes: '(min-width: 750px) 55vw, 100vw'
        }}
      {% endif %}
    </div>
    <div class="story-hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="story-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="story-hero__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.intro != blank %}
        <div class="story-hero__intro rte">{{ section.settings.intro }}</div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .story-hero {
    padding-block: 48px;
  }

  .story-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .story-hero__grid {
      grid-template-columns: 3fr 2fr;
      gap: 48px;
    }
  }

  .story-hero__media {
    --story-hero-media-height: 42svh;
  }

  .story-hero__image {
    display: block;
    width: 100%;
    height: var(--story-hero-media-height);
    min-height: 260px;
    object-fit: cover;
    border-radius: 16px;
  }

  .story-hero__content {
    text-align: right;
  }

  .story-hero__eyebrow {
    font-family: var(--font-accent--family);
    font-size: 1rem;
    letter-spacing: 0.08em;
    color: #1a1a2e;
    margin: 0 0 12px;
  }

  .story-hero__heading {
    color: #1a1a2e;
    margin: 0 0 16px;
  }

  .story-hero__intro {
    font-size: 1.125rem;
    line-height: 1.7;
    color: #1a1a2e;
  }

  .story-hero__intro p {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Story hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text"
    },
    {
      "type": "text",
      "id": "media_height",
      "label": "Media height",
      "default": "42svh"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f7f5f2"
    }
  ]
}
{% endschema %}
