

<div
  class="story-editorial"
  style="background-color: {{ section.settings.background_color }}; padding-block-start: {{ section.settings.padding-block-start }}px; padding-block-end: {{ section.settings.padding-block-end }}px;"
>
  <div class="story-editorial__container">
    {% if section.settings.eyebrow != blank %}
      <p class="story-editorial__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="story-editorial__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="story-editorial__row">
      <span class="story-editorial__rule" aria-hidden="true"></span>
      <div class="story-editorial__body rte">
        {{ section.settings.body }}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .story-editorial__container {
    max-width: 46rem;
    margin-inline: auto;
    padding-inline: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .story-editorial__eyebrow {
    font-family: var(--font-accent--family);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    color: {{ settings.color_palette.color1 }};
    margin: 0 0 16px;
  }

  .story-editorial__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.75rem, 1.4rem + 1.5vw, 2.5rem);
    line-height: 1.25;
    color: {{ settings.color_palette.color1 }};
    text-align: center;
    margin: 0 0 40px;
  }

  .story-editorial__row {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    width: 100%;
  }

  .story-editorial__rule {
    flex: none;
    width: 2px;
    align-self: stretch;
    background-color: {{ settings.color_palette.color1 }};
    opacity: 0.25;
    border-radius: 2px;
  }

  .story-editorial__body {
    flex: 1;
    text-align: right;
    font-family: var(--font-body--family);
    font-size: 1.15rem;
    line-height: 1.85;
    color: {{ settings.color_palette.color1 }};
  }

  .story-editorial__body p {
    margin: 0 0 1.1em;
  }

  .story-editorial__body p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .story-editorial__heading {
      margin-bottom: 28px;
    }

    .story-editorial__body {
      font-size: 1.05rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Story editorial",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "התהליך שלנו"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "מהסקיצה הראשונה ועד הקיר שלכם"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f7f5f2"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "Story editorial"
    }
  ]
}
{% endschema %}
