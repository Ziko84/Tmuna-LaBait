{% liquid
  assign show_banner = true
  assign banner_collection = section.settings.collection

  if section.settings.mode == 'search_empty'
    if search.results_count > 0 or search.results_count == blank
      assign show_banner = false
    endif
  endif

  if banner_collection == blank and section.settings.mode == 'auto_cross_sell'
    for c in collections
      assign is_excluded = false
      if c.handle == 'frontpage' or c.products_count == 0
        assign is_excluded = true
      endif
      if closest.product != blank and is_excluded == false
        for pc in closest.product.collections
          if pc.handle == c.handle
            assign is_excluded = true
          endif
        endfor
      endif
      if is_excluded == false and banner_collection == blank
        assign banner_collection = c
      endif
    endfor
  endif

  if banner_collection == blank
    assign show_banner = false
  endif

  assign banner_heading = section.settings.heading | default: banner_collection.title
  assign banner_image = section.settings.image | default: banner_collection.image | default: banner_collection.products.first.featured_image
  assign banner_cta = section.settings.cta_label | default: 'לגלות את הקולקציה'
%}

{% if show_banner %}
  <div class="collection-banner page-width-content" style="background-color: {{ section.settings.background_color }};">
    <div class="collection-banner__grid">
      <div class="collection-banner__media">
        {% if banner_image != blank %}
          {{
            banner_image
            | image_url: width: 1600
            | image_tag: loading: 'lazy', class: 'collection-banner__image', sizes: '(min-width: 750px) 50vw, 100vw'
          }}
        {% endif %}
      </div>
      <div class="collection-banner__content">
        {% if section.settings.eyebrow != blank %}
          <p class="collection-banner__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if banner_heading != blank %}
          <h2 class="collection-banner__heading">{{ banner_heading }}</h2>
        {% endif %}
        {% if section.settings.body != blank %}
          <div class="collection-banner__body rte">{{ section.settings.body }}</div>
        {% endif %}
        {% if banner_collection.url %}
          <a href="{{ banner_collection.url }}" class="button-custom collection-banner__cta">{{ banner_cta }}</a>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .collection-banner {
    padding-block: 48px;
  }

  .collection-banner__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .collection-banner__grid {
      grid-template-columns: 1fr 1fr;
      gap: 56px;
    }
  }

  .collection-banner__media {
    aspect-ratio: 1 / 1;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 12px 28px rgb(0 0 0 / 0.14), 0 3px 10px rgb(0 0 0 / 0.08);
  }

  .collection-banner__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .collection-banner__content {
    text-align: right;
  }

  .collection-banner__eyebrow {
    font-family: var(--font-accent--family);
    font-size: 1rem;
    letter-spacing: 0.08em;
    color: #1a1a2e;
    margin: 0 0 12px;
  }

  .collection-banner__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight, 600);
    font-size: clamp(1.85rem, 1.3rem + 2.2vw, 2.75rem);
    line-height: 1.15;
    color: #1a1a2e;
    margin: 0 0 16px;
  }

  .collection-banner__body {
    font-size: 1.125rem;
    line-height: 1.7;
    color: #1a1a2e;
    margin: 0 0 24px;
  }

  .collection-banner__body p {
    margin: 0;
  }

  .collection-banner__cta {
    display: inline-block;
    padding: 14px 32px;
    border-radius: 999px;
    background-color: #1a1a2e;
    color: #ffffff;
    text-decoration: none;
    font-size: 0.95rem;
    transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .collection-banner__cta:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection banner",
  "settings": [
    {
      "type": "select",
      "id": "mode",
      "label": "Mode",
      "options": [
        { "value": "manual", "label": "Manual collection" },
        { "value": "auto_cross_sell", "label": "Auto cross-sell (excludes current product)" },
        { "value": "search_empty", "label": "Show only when search has no results" }
      ],
      "default": "manual"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image override"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "גלו עוד"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading override"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "לגלות את הקולקציה"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f7f5f2"
    }
  ],
  "presets": [
    {
      "name": "Collection banner"
    }
  ]
}
{% endschema %}
