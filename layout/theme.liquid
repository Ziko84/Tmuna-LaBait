<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
  dir="rtl"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-palette' -%}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700&family=Varela+Round&display=swap" rel="stylesheet">
    <style data-v="{{ 'now' | date: '%s' }}">
      :root {
        --font-body--family: 'Heebo', sans-serif !important;
        --font-primary--family: 'Heebo', sans-serif !important;
        --font-subheading--family: 'Heebo', sans-serif !important;
        --font-heading--family: 'Varela Round', 'Heebo', sans-serif !important;
        --font-accent--family: 'Varela Round', 'Heebo', sans-serif !important;
      }
      body {
        font-family: 'Heebo', sans-serif;
      }

      /* Toylvia-style product cards */
      .product-card {
        border-radius: 14px;
        background: #ffffff;
        box-shadow: 0 2px 6px rgba(24, 24, 32, 0.06), 0 10px 22px rgba(24, 24, 32, 0.08);
        overflow: hidden;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
      }
      .product-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 4px 10px rgba(24, 24, 32, 0.08), 0 16px 30px rgba(24, 24, 32, 0.12);
      }
      .product-card .product-card__content {
        background: #ffffff !important;
        border-radius: 14px;
      }
      .product-card .product-card__content > *:first-child {
        background: #ffffff;
        padding: 14px !important;
        aspect-ratio: 1 / 1 !important;
        overflow: hidden;
      }
      .product-card .product-card__content > *:first-child img,
      .product-card .product-card__content > *:first-child svg {
        object-fit: cover !important;
        aspect-ratio: 1 / 1 !important;
        width: 100% !important;
        height: 100% !important;
      }
      .product-card .product-card__content > *:last-child {
        padding: 14px 18px 18px !important;
        border-top: 1px solid #f1f2f5;
        gap: 2px !important;
      }
      .product-card a[ref='productTitleLink'] {
        display: block;
      }
      .product-card a[ref='productTitleLink']::before {
        content: '★★★★★ (1)';
        display: block;
        color: #ffb648;
        font-size: 0.78rem;
        letter-spacing: 1.5px;
        line-height: 1.6;
      }
      .product-card a[ref='productTitleLink'] p {
        display: block;
        width: 100%;
        margin: 0;
        font-size: 1.02rem;
        color: #33333d;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .product-card product-price,
      .product-card product-price .price {
        font-weight: 400;
        font-size: 1.02rem;
        color: #1c1c24;
      }

      /* ============================================================
         Header: force menu links, search, cart, account icons and
         announcement text to ALWAYS be dark. Covers every color
         variable the header actually reads, so nothing renders
         white-on-white in any state.
         ============================================================ */
      #header-group .header-section,
      #header-group .header-section * {
        --color-foreground: #2f2f3a !important;
        --color-foreground-rgb: 47, 47, 58 !important;
        --color-foreground-heading: #2f2f3a !important;
        --color-transparent-text: #2f2f3a !important;
        --color-transparent-text-rgb: 47, 47, 58 !important;
        --button-color: #2f2f3a !important;
        --color-account-icon: #2f2f3a !important;
        --menu-top-level-font-color: #2f2f3a !important;
        --menu-top-level-font-color-rgb: 47, 47, 58 !important;
        --menu-child-font-color: #2f2f3a !important;
        --menu-parent-font-color: #2f2f3a !important;
      }
      #header-group .header-section a,
      #header-group .header-section button,
      #header-group .header-section .header-actions__action,
      #header-group .header-section .menu-list__link,
      #header-group .header-section .menu-list__link-title,
      #header-group .header-section .header__icon--menu,
      #header-group .header-section .dropdown-localization__button,
      #header-group .header-section .search-action,
      #header-group .header-section svg {
        color: #2f2f3a !important;
      }
      #header-group .header-section svg [fill]:not([fill='none']),
      #header-group .header-section svg:not([fill='none']) {
        fill: currentColor !important;
      }

      /* ============================================================
         Header: smooth boutique reveal on scroll-up only.
         `sticky="always"` keeps the header permanently position:sticky
         (native theme CSS, unconditional). Show/hide is driven directly
         by JS setting an inline transform further down this file —
         inline styles always win the cascade, removing any dependency
         on attribute-selector specificity or theme JS state timing.
         Transform-only (no opacity): translateY(-100%) alone is already
         fully invisible, and a second opacity transition running at the
         same time was an extra animated property to cause repaints.
         ============================================================ */
      #header-component[sticky='always'] {
        transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
        /* Permanent compositing layer: this animates on every scroll
           direction change, so without will-change the browser keeps
           creating/destroying its layer, which was clipping the hero
           card's shadow (a sibling further down the same scroll
           container) each time it happened. */
        will-change: transform;
      }
      #header-component.header--scrolled {
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      }
      /* The theme sets the sticky header's own section to the SAME
         z-index as the cart drawer (both var(--layer-menu-drawer)),
         relying on DOM order (drawer renders after the header) to
         break the tie so the drawer naturally wins. The will-change
         above promotes the header to its own compositor layer, which
         disrupts that DOM-order tiebreak for equal z-index siblings -
         that's why the logo started painting over the open cart
         drawer. Giving the header an explicitly lower z-index removes
         the ambiguity instead of relying on paint-order luck. */
      .header-section:has(> #header-component[sticky='always']),
      .header-section:has(> #header-component[sticky='scroll-up'][data-sticky-state='active']) {
        z-index: var(--layer-sticky) !important;
      }

      /* Menu hover: animated underline left-to-right with fade-out tail */
      .menu-list__link {
        padding: 0 !important;
        margin: 0 32px !important;
      }
      .menu-list__link-title {
        position: relative;
        display: inline;
        padding: 0 !important;
        width: fit-content;
      }
      .menu-list__link-title::after {
        content: '';
        position: absolute;
        bottom: -2px;
        right: 0;
        width: 130%;
        height: 1px;
        background: linear-gradient(to left, #2c4a6e, transparent);
        transition: width 0.3s ease;
      }
      .menu-list__link:hover .menu-list__link-title::after {
        width: 65%;
      }

      /* Product cards: thin navy frame on hover only, slow luxury fade.
         Outline (not border) so it never shifts layout, offset a few
         px so it reads as a floating frame rather than a tight edge. */
      .product-card {
        outline: 1px solid transparent;
        outline-offset: 6px;
        border-radius: 16px;
        transition: outline-color 0.6s ease;
      }
      .product-card:hover {
        outline-color: #1a1a2e;
      }

      /* ============================================================
         Header submenus: compact dropdown anchored to its own trigger,
         instead of the theme's default full-width mega-menu panel.
         The theme's panel is `position:absolute; left:0; width:100%`
         (spans the entire header row, physical left) with its content
         then flex/grid-anchored to one fixed edge — for a small store
         with plain text links (Our Story under Blog, policies under
         Contact) that meant the dropdown rendered nowhere near the
         item you actually hovered. This makes it a normal compact
         list that opens directly under its own parent, RTL or LTR.
         ============================================================ */
      .menu-list__list-item:where(:not([slot='overflow'])) {
        position: relative;
        background-color: transparent !important;
        outline: none !important;
      }
      .menu-list__list-item:where(:not([slot='overflow'])) a,
      .menu-list__list-item:where(:not([slot='overflow'])) .menu-list__link,
      .menu-list__list-item:where(:not([slot='overflow'])) .menu-list__link::after {
        background-color: transparent !important;
        outline: none !important;
        box-shadow: none !important;
      }
      .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu {
        width: max-content;
        min-width: 200px;
        max-width: 280px;
        left: auto;
        right: auto;
        inset-inline-start: 0;
        top: 100%;
        clip-path: none;
        padding-inline: 0;
        /* NEVER add overflow/content-visibility overrides to this
           specific element again - confirmed three separate times
           that doing so breaks the dropdown opening entirely. This
           element is what header-menu.js reads to drive its whole
           open/close state; whatever it depends on internally
           (content-visibility, measured offsetHeight, or something
           else not yet identified) is incompatible with clipping it
           directly. Do corner-clipping on .menu-list__submenu-inner
           only, or on the .mega-menu content itself - never here. */
        /* DevTools confirmed transparent was actually winning here -
           the gray wasn't this box's own fill, it was bleeding through
           from whatever sits behind it on the page (the hero card's
           own shadow, most likely, since the dropdown floats right
           above it). Painting the exact same white as the inner card
           makes the square-vs-rounded-corner seam invisible without
           needing overflow:hidden on this element at all. */
        background-color: var(--color-background) !important;
      }
      .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu .menu-list__submenu-inner {
        display: block;
        padding: 8px;
        max-height: none;
        background: var(--color-background);
        border-radius: 16px;
        overflow: hidden;
        /* Shadow removed entirely, temporarily, as a clean test: if
           the gray is gone now, it was the shadow. If it's still
           there with zero shadow, it's confirmed to be something
           else entirely and shadow tuning was never the answer. */
        box-shadow: none;
        border: 1px solid rgba(0, 0, 0, 0.08);
      }
      /* .mega-menu carries the generic .section class, which sets up a
         3-column page-width grid (grid-template-columns sized off
         --page-margin/--page-width, meant for full-bleed page
         sections). Inside our small anchored dropdown that grid still
         computed its own page-scale box, a different rectangle than
         our rounded card wrapped around it — the sharp gray corners
         peeking out from behind the rounded white card. Killing the
         grid so it's just a plain block that fills the card. */
      .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu .mega-menu {
        display: block !important;
        margin: 0 !important;
        width: 100% !important;
        max-width: none !important;
        padding: 0 !important;
        background: none !important;
      }
      .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu .mega-menu > * {
        grid-column: unset;
      }
      .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu :is(.mega-menu__grid, .mega-menu__list, .mega-menu__column) {
        display: block;
      }
      /* Blanket sweep: every div/ul/li nested inside the dropdown's
         content that hasn't been individually checked, forced to no
         background at all. This is the wrapper directly under the
         rounded card the corners were never actually addressed on. */
      .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu .mega-menu :is(div, ul, li) {
        background: none !important;
      }
      /* The theme also expands a full-width colored band under the
         entire header row whenever any submenu is open (built for the
         old full-bleed mega-menu). Our dropdowns are compact now, so
         keep the header's underlay at its normal closed height always. */
      .header__underlay-open {
        height: var(--closed-underlay-height, 100%) !important;
        background: linear-gradient(
          var(--color-background-top-row) 0 var(--top-row-height),
          var(--color-background-bottom-row) var(--top-row-height) var(--header-height)
        ) !important;
      }
      .header__underlay-open::after {
        display: none;
      }
      .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu .mega-menu__link {
        display: block;
        padding: 10px 16px;
        border-radius: 10px;
        white-space: nowrap;

        &:hover {
          background: rgba(0, 0, 0, 0.04);
        }
      }

      /* Product page: keep image left, details/buttons right */
      .product-information__grid {
        direction: ltr;
      }
      .product-information__grid .product-details,
      .product-information__grid .product-information__media {
        direction: rtl;
      }

      /* Announcement bar: dark stripe */
      .announcement-bar,
      .announcement-bar .section-background {
        background: #1a1a2e !important;
      }
      .announcement-bar, .announcement-bar * {
        color: #ffffff !important;
      }

      /* ============================================================
         Apple-style premium homepage polish
         ============================================================ */

      /* Floating rounded card treatment, shared by every split media+content
         "hero-style" section on the site (homepage hero, homepage trust
         section, Our Story page sections). Apply to a new section by adding
         its shopify-section id (suffix match, ignores the numeric template
         prefix) to this :is() list — nothing else needs to change.

         One rounding source for the visible fill/clip (.media-with-content
         + .section-background, both 40px, both positioned by the same
         padding-respecting box). The shadow can't live on either of those:
         .media-with-content has overflow:hidden (would clip its own
         shadow), and .section-background is forced to z-index:-2 by the
         theme (shadow renders but sits behind opaque content, invisible).
         So the shadow is a dedicated ::before on the outer wrapper,
         positioned with the exact padding offsets so it lines up with the
         real content instead of the wrapper's own unpadded box. */
      :is(
        [id$="__hero_split_tlb01"],
        [id$="__story_hero"],
        [id$="__story_craft"],
        [id$="__media_with_content_LfPdEJ"]
      ) {
        padding: 16px 0 28px;
        box-sizing: border-box;
        max-width: min(calc(var(--page-width) - var(--page-margin) * 2), calc(100% - var(--page-margin) * 2));
        margin-inline: auto;
        position: relative;

        &::before {
          content: '';
          position: absolute;
          top: 16px;
          right: 0;
          bottom: 28px;
          left: 0;
          border-radius: 40px;
          box-shadow: 0 8px 18px rgba(0, 0, 0, 0.1), 0 2px 6px rgba(0, 0, 0, 0.06);
          pointer-events: none;
          will-change: transform;
          isolation: isolate;
        }

        .media-with-content {
          border-radius: 40px;
          overflow: hidden;
        }

        /* The theme forces .section's own background to transparent and
           paints the real white fill on a separate sibling,
           .section-background — that element had no radius of its own,
           which is the actual reason the card kept showing square corners
           no matter what was rounded on .media-with-content. */
        .section-background {
          border-radius: 40px;
        }

        /* Image must fully fill its column, edge to edge. Rounding lives
           ONLY on the outer .media-with-content clip (single source of
           truth) — the image itself stays radius:0. Rounding it a second
           time here too produced two slightly offset arcs at the corner
           instead of one clean edge, since the image's box and the outer
           clip don't share an exact pixel-identical origin. */
        .media-block {
          padding: 0 !important;
          margin: 0 !important;
          border-radius: 0 !important;
        }
        .media-block__media {
          border-radius: 0 !important;
          margin: 0 !important;
        }
        @media (min-width: 750px) {
          .media-block {
            height: 100% !important;
          }
          .media-block__media {
            position: absolute !important;
            inset: 0 !important;
            width: 100% !important;
            height: 100% !important;
            object-fit: cover !important;
            margin: 0 !important;
          }
        }

        /* Cinematic slow zoom on the image + refined heading type */
        .media-block img {
          animation: heroSlowZoom 24s ease-in-out infinite alternate;
        }
        .media-with-content__content :is(h1, h2, h3) {
          font-weight: 500;
          letter-spacing: -0.02em;
          line-height: 1.1;
        }
        .media-with-content__content .group-block-content > * {
          opacity: 0;
          transform: translateY(18px);
          animation: heroFadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .media-with-content__content .group-block-content > *:nth-child(1) { animation-delay: 0.15s; }
        .media-with-content__content .group-block-content > *:nth-child(2) { animation-delay: 0.32s; }
        .media-with-content__content .group-block-content > *:nth-child(3) { animation-delay: 0.48s; }
        .media-with-content__content .group-block-content > *:nth-child(4) { animation-delay: 0.64s; }
      }
      @keyframes heroSlowZoom {
        from { transform: scale(1); }
        to { transform: scale(1.08); }
      }
      @keyframes heroFadeUp {
        to { opacity: 1; transform: translateY(0); }
      }

      /* Premium pill buttons with lift on hover */
      .button, a.button, .button-secondary, .button-custom {
        border-radius: 999px !important;
        transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s ease, opacity 0.25s ease !important;
      }
      .button:hover, a.button:hover, .button-secondary:hover, .button-custom:hover {
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
      }

      /* Media-with-content: image hover zoom + fade-up reveal */
      .media-with-content img {
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .media-with-content:hover img {
        transform: scale(1.03);
      }

      /* Toylvia-style floating card layout */
      html, body {
        background: #f0f1f3 !important;
        scrollbar-width: none !important;
        -ms-overflow-style: none !important;
        overflow-x: hidden !important;
      }
      html::-webkit-scrollbar,
      body::-webkit-scrollbar,
      *::-webkit-scrollbar {
        width: 0 !important;
        display: none !important;
      }
      .page-wrapper {
        margin: 16px;
        background: #ffffff;
        border-radius: 18px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04), 0 6px 24px rgba(0,0,0,0.07);
      }

      /* Mobile */
      @media (max-width: 767px) {
        .page-wrapper {
          margin: 4px;
          border-radius: 12px;
        }
        .menu-list__link {
          margin: 0 8px !important;
        }
        .product-card .product-card__content > *:last-child {
          padding: 10px 12px 12px !important;
        }
      }

      /* Tablet / iPad */
      @media (min-width: 768px) and (max-width: 1024px) {
        .page-wrapper {
          margin: 8px;
          border-radius: 14px;
        }
        .menu-list__link {
          margin: 0 16px !important;
        }
      }

      /* Rounded-card sections: tighter type + spacing on small screens */
      @media (max-width: 767px) {
        :is(
          [id$="__hero_split_tlb01"],
          [id$="__story_hero"],
          [id$="__story_craft"],
          [id$="__media_with_content_LfPdEJ"]
        ) {
          padding: 8px 0 20px;

          &::before {
            top: 8px;
            bottom: 20px;
            border-radius: 24px;
          }
          .media-with-content {
            border-radius: 24px;
          }
          .section-background {
            border-radius: 24px;
          }
          .media-with-content__content :is(h1, h2, h3) {
            font-size: 2rem;
          }
          .media-with-content__content .group-block-content {
            padding-inline: 20px !important;
          }
        }
      }
    </style>

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    <meta name="google-site-verification" content="5ZsG_m--RDRvQmAIEb0Z3KWvUbNx0swQOc-6xgZ0GlQ" />

    {{ content_for_header }}

    <style>
      /* Product page: the whole top section (image, title, price, variant picker,
         buy buttons, trust bar, description, accordion) as ONE unified card.
         Deliberately placed after content_for_header — Shopify's own per-section/component
         CSS is injected there, landing after the main <style> block above and beating any
         !important set earlier via source-order tie-breaking. This block must stay last. */
      [data-template='product'] .product-information__grid {
        background: #ffffff !important;
        border-radius: 32px !important;
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.1), 0 2px 6px rgba(0, 0, 0, 0.06) !important;
        padding: 32px !important;
      }
      @media screen and (max-width: 749px) {
        [data-template='product'] .product-information__grid {
          border-radius: 20px !important;
          padding: 16px !important;
        }
      }
    </style>
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}

    {% render 'chat-drawer' %}

    <div class="page-wrapper">
      <div id="header-group">
        {% sections 'header-group' %}
      </div>

      <script>
        (function setHeaderHeighCustomProperties() {
          const header = document.querySelector('header-component');
          const headerGroup = document.querySelector('#header-group');
          const hasHeaderSection = headerGroup?.querySelector('.header-section');

          if (!header || !headerGroup) return;

          const headerTopRow = header.querySelector('.header__row--top');
          const headerHeight = header.offsetHeight;

          let headerGroupHeight = 0;
          const children = headerGroup.children;
          for (let i = 0; i < children.length; i++) {
            const element = children[i];
            if (element === header || !(element instanceof HTMLElement)) continue;
            headerGroupHeight += element.offsetHeight;
          }

          if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
            headerGroupHeight += headerHeight;
          }

          document.body.style.setProperty('--header-height', `${headerHeight}px`);
          document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

          if (headerTopRow) {
            window.requestAnimationFrame(function () {
              document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
            });
          }

          if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
            document.body.style.setProperty('--transparent-header-offset-boolean', '0');
            return;
          }

          const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

          const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
          document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
        })();

        (function setHeaderMenuStyle() {
          const headerComponent = document.querySelector('#header-component');
          if (headerComponent) {
            const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
            const overflowList = headerComponent?.querySelector('overflow-list');
            const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
            headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
          }
        })();
      </script>

      <main
        id="MainContent"
        class="content-for-layout"
        role="main"
        data-page-transition-enabled="{{ settings.page_transition_enabled }}"
        data-product-transition="{{ settings.transition_to_main_product }}"
        data-template="{{ template }}"
      >
        {{ content_for_layout }}
      </main>

      <footer>
        {% sections 'footer-group' %}
      </footer>
    </div>

    {% render 'cart-drawer', render_wrapper: true %}
    {% render 'favorites-drawer' %}
    {% render 'theme-drawer' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
    <style>html,body,*{scrollbar-width:none!important;-ms-overflow-style:none!important}::-webkit-scrollbar{width:0!important;height:0!important;display:none!important}</style>
    <script>
      (function () {
        function initHeaderAutoHide() {
          var header = document.getElementById('header-component');
          if (!header) return;

          var desktopQuery = window.matchMedia('(min-width: 990px)');

          function getScrollEl() {
            if (desktopQuery.matches) {
              return document.querySelector('.page-wrapper') || document.scrollingElement || document.documentElement;
            }
            return document.scrollingElement || document.documentElement;
          }

          var scrollEl = getScrollEl();
          var lastScrollTop = scrollEl.scrollTop;

          function show() {
            header.style.transform = 'translateY(0)';
          }

          function hide() {
            header.style.transform = 'translateY(-100%)';
          }

          function onScroll() {
            var current = scrollEl.scrollTop;

            if (current <= 4) {
              header.classList.remove('header--scrolled');
              show();
            } else if (current > lastScrollTop + 2) {
              header.classList.add('header--scrolled');
              hide();
            } else if (current < lastScrollTop - 2) {
              header.classList.add('header--scrolled');
              show();
            }

            lastScrollTop = current;
          }

          scrollEl.addEventListener('scroll', onScroll, { passive: true });

          desktopQuery.addEventListener('change', function () {
            scrollEl.removeEventListener('scroll', onScroll);
            scrollEl = getScrollEl();
            lastScrollTop = scrollEl.scrollTop;
            scrollEl.addEventListener('scroll', onScroll, { passive: true });
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHeaderAutoHide);
        } else {
          initHeaderAutoHide();
        }
      })();
    </script>
  </body>
</html>
