{%- doc -%}
  Sticky "quick add to cart" bar for product pages.

  Appears once the real buy box has scrolled above the viewport, keeping
  price + Add to cart reachable without scrolling back up. Clicking its
  button just clicks the real add-to-cart button, so variant selection,
  cart-drawer opening, and loading states are all the theme's own existing
  logic, not duplicated.
{%- enddoc -%}

{%- if product -%}
  <div
    class="sticky-buy-bar"
    id="StickyBuyBar"
    aria-hidden="true"
  >
    <div class="sticky-buy-bar__inner">
      <div class="sticky-buy-bar__media">
        {%- if product.featured_media -%}
          <img
            src="{{ product.featured_media | image_url: width: 100 }}"
            width="50"
            height="50"
            alt=""
            loading="lazy"
          >
        {%- endif -%}
      </div>
      <div class="sticky-buy-bar__info">
        <span class="sticky-buy-bar__title">{{ product.title }}</span>
        <span
          class="sticky-buy-bar__price"
          id="StickyBuyBarPrice"
        >{{ product.price | money }}</span>
      </div>
      <button
        type="button"
        class="button sticky-buy-bar__cta"
        id="StickyBuyBarButton"
      >
        הוספה לעגלה
      </button>
    </div>
  </div>

  <script>
    (function () {
      function init() {
        var bar = document.getElementById('StickyBuyBar');
        var ctaButton = document.getElementById('StickyBuyBarButton');
        if (!bar || !ctaButton) return;

        var realButton = document.querySelector('.product-information__grid button[name="add"]');
        if (!realButton) return;

        var realPriceEl = document.querySelector('.product-information__grid product-price .price');
        var priceTarget = document.getElementById('StickyBuyBarPrice');

        function syncPrice() {
          if (realPriceEl && priceTarget && realPriceEl.textContent.trim()) {
            priceTarget.textContent = realPriceEl.textContent.trim();
          }
        }
        syncPrice();
        if (realPriceEl && window.MutationObserver) {
          new MutationObserver(syncPrice).observe(realPriceEl, {
            childList: true,
            characterData: true,
            subtree: true,
          });
        }

        ctaButton.addEventListener('click', function () {
          realButton.click();
        });

        if ('IntersectionObserver' in window) {
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                // Show only once the real button has scrolled above the
                // viewport (the user scrolled past it going down), not
                // before it has ever been reached.
                var scrolledPast = !entry.isIntersecting && entry.boundingClientRect.top < 0;
                bar.classList.toggle('sticky-buy-bar--visible', scrolledPast);
                bar.setAttribute('aria-hidden', scrolledPast ? 'false' : 'true');
              });
            },
            { threshold: 0 }
          );
          observer.observe(realButton);
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
{%- endif -%}
