{%- doc -%}
  Hover crossfade for the homepage banners: swaps the day shot for a
  pixel-aligned night version (lights off / LED glow on) on hover.
  Maps a section id suffix to a theme asset filename below - add a new
  entry to cover another banner.

  @example
  {% render 'hero-night-mode' %}
{%- enddoc -%}

<script>
  (function () {
    var nightImages = {
      '__hero_split_tlb01': {{ 'hero-night.png' | asset_url | json }},
      '__media_with_content_LfPdEJ': {{ 'banner-night.png' | asset_url | json }}
    };

    function initBannerNightMode() {
      Object.keys(nightImages).forEach(function (suffix) {
        var container = document.querySelector('[id$="' + suffix + '"] .media-block');
        if (!container || container.querySelector('.hero-night-image')) return;
        var img = document.createElement('img');
        img.className = 'hero-night-image';
        img.src = nightImages[suffix];
        img.alt = '';
        img.loading = 'lazy';
        container.appendChild(img);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBannerNightMode);
    } else {
      initBannerNightMode();
    }
  })();
</script>
