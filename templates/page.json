{
  "sections": {
    "banner": {
      "type": "section",
      "blocks": {
        "title": {
          "type": "text",
          "name": "Title",
          "settings": {
            "text": "<h1>{{ closest.page.title }}</h1>",
            "width": "100%",
            "max_width": "normal",
            "alignment": "center",
            "type_preset": "h2",
            "font": "var(--font-heading--family)",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
            "wrap": "pretty",
            "background": false,
            "background_color": "#00000026",
            "corner_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        }
      },
      "block_order": [
        "title"
      ],
      "name": "Page banner",
      "settings": {
        "content_direction": "column",
        "horizontal_alignment": "center",
        "vertical_alignment": "center",
        "section_width": "page-width",
        "background_color": "{{ settings.color_palette.background }}",
        "padding-block-start": 48,
        "padding-block-end": 48
      }
    },
    "main": {
      "type": "main-page",
      "blocks": {
        "page-content": {
          "type": "page-content",
          "settings": {},
          "blocks": {}
        }
      },
      "block_order": [
        "page-content"
      ],
      "settings": {
        "content_direction": "column",
        "gap": 32,
        "background_color": "{{ settings.color_palette.background }}",
        "padding-block-start": 0,
        "padding-block-end": 80
      }
    }
  },
  "order": [
    "banner",
    "main"
  ]
}
