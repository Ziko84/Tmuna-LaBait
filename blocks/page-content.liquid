

<div
  class="page-content"
  style="
    {% if block.settings.text_color != blank %}
      --color: {{ block.settings.text_color }};
      --color-rgb: {{ block.settings.text_color.rgb }};
    {% endif %}
  "
>
  <rte-formatter>
    {{ page.content }}
  </rte-formatter>
</div>

{% stylesheet %}
  .page-content {
    color: var(--color, inherit);
    font-size: 1.15rem;
    line-height: 1.8;
  }

  .page-content h2 {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-block: 2em 0.7em;
  }

  .page-content h2:first-child {
    margin-block-start: 0;
  }

  .page-content p {
    margin-block: 1.4em;
  }

  .page-content ul,
  .page-content ol {
    margin-block: 1.2em;
    padding-inline-start: 1.4em;
  }

  .page-content li {
    margin-block: 0.5em;
  }

  .page-content li::marker {
    color: rgb(var(--color-foreground-rgb) / 50%);
  }

  .page-content a {
    color: currentcolor;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.page_content",
  "class": "rte",
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text_color",
      "placeholder": "t:settings.default"
    }
  ]
}
{% endschema %}
