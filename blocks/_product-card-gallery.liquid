

{% assign product = closest.product %}

{% capture children %}
  {% unless product == blank %}
    <script
      type="module"
      src="{{ 'favorites.js' | asset_url }}"
      fetchpriority="low"
    ></script>
    <favorite-toggle
      class="favorite-toggle"
      data-product-handle="{{ product.handle }}"
      role="button"
      tabindex="0"
      aria-pressed="false"
      aria-label="{{ 'accessibility.add_to_favorites' | t }}"
      on:click="/toggle"
    >
      <span class="svg-wrapper favorite-toggle__icon favorite-toggle__icon--outline" aria-hidden="true">
        {{- 'icon-heart.svg' | inline_asset_content -}}
      </span>
      <span class="svg-wrapper favorite-toggle__icon favorite-toggle__icon--filled" aria-hidden="true">
        {{- 'icon-heart-filled.svg' | inline_asset_content -}}
      </span>
    </favorite-toggle>
    <div
      class="product-badges product-badges--{{ settings.badge_position }}"
      style="
        --badge-border-radius: {{ settings.badge_corner_radius }}px;
        --badge-font-family: var(--font-{{ settings.badge_font_family }}--family); --badge-font-weight: var(--font-{{ settings.badge_font_family }}--weight); --badge-text-transform: {{ settings.badge_text_transform }};
      "
    >
      {%- if product.available == false or product.compare_at_price > product.price -%}
        <div
          class="
            product-badges__badge product-badges__badge--rectangle
            {% if product.available == false %} color-custom-badge-sold-out{% elsif product.compare_at_price > product.price %} color-custom-badge-sale{% endif %}
          "
        >
          {%- if product.available == false -%}
            {{ 'content.product_badge_sold_out' | t }}
          {%- elsif product.compare_at_price > product.price -%}
            {{ 'content.product_badge_sale' | t }}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
    {%  if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add', product: product, section_id: section.id %}
    {% endif %}
  {% endunless %}
{% endcapture %}

{% render 'card-gallery', children: children %}

{% # Title and price for the zoomed out grid view %}
<div class="product-grid-view-zoom-out--details">
  {% if product == blank %}
    <h3 class="h4">{{ 'content.product_card_placeholder' | t }}</h3>
  {% else %}
    <h3 class="h4">{{ product.title }}</h3>
  {% endif %}
</div>

{% render 'product-badges-styles' %}

{% stylesheet %}
  .favorite-toggle {
    position: absolute;
    top: var(--padding-xs, 10px);
    inset-inline-end: var(--padding-xs, 10px);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background-color: rgb(255 255 255 / 0.92);
    box-shadow: 0 1px 4px rgb(0 0 0 / 0.1);
    color: #1a1a2e;
    cursor: pointer;
    opacity: 1;
    transform: scale(1);
    transition: transform var(--hover-transition-duration, 0.2s) var(--hover-transition-timing, ease),
      opacity var(--hover-transition-duration, 0.2s) var(--hover-transition-timing, ease),
      background-color var(--hover-transition-duration, 0.2s) var(--hover-transition-timing, ease);
  }

  @media (hover: hover) {
    .favorite-toggle:not(.is-favorite) {
      opacity: 0;
      transform: scale(0.85);
    }

    .card-gallery:hover .favorite-toggle,
    .favorite-toggle:focus-visible {
      opacity: 1;
      transform: scale(1);
    }
  }

  .favorite-toggle:hover {
    transform: scale(1.1);
    background-color: #ffffff;
  }

  .favorite-toggle__icon {
    width: 15px;
    height: 15px;
    display: block;
  }

  .favorite-toggle__icon--filled {
    display: none;
    color: #ec4899;
  }

  .favorite-toggle.is-favorite .favorite-toggle__icon--outline {
    display: none;
  }

  .favorite-toggle.is-favorite .favorite-toggle__icon--filled {
    display: block;
  }

  @keyframes favorite-toggle-pulse {
    0% {
      transform: scale(1);
    }
    35% {
      transform: scale(1.28);
    }
    100% {
      transform: scale(1);
    }
  }

  .favorite-toggle--pulse .favorite-toggle__icon {
    animation: favorite-toggle-pulse 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_image",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_media"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "portrait",
      "label": "t:settings.aspect_ratio",
      "info": "t:info.aspect_ratio_adjusted"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "t:settings.color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_card_media",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
